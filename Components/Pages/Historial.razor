@page "/venta"
@rendermode InteractiveServer
@using FarmaciaSimilares01.Models
@using FarmaciaSimilares01.Data 
@using Microsoft.EntityFrameworkCore
@inject HttpClient Http
@inject MedicamentosDbContext DbContext

<PageTitle>Farmacia Similares</PageTitle>



    <header>

        <nav class="nav-page">
            <ul>
                <div class="logo-img">
                    <img src="/img/logo-similares.png" alt="">
                </div>
                <li><a href="/">Inicio</a></li>
                <li><a href="/catalogo">Catálogo</a></li>
                <li><a href="/sistemaCRUD">Registrarte</a></li>
                <li><a href="/venta">Historial</a></li>
            </ul>

        </nav>

    </header>














<div class="caja-registradora-gigante">



    <div class="titulo-de-arriba">
        <h2><i class="bi bi-capsule"></i> Comprar</h2> 
    </div>



    @* =========================================== *@
    @* --- ALERTA DE ÉXITO AL GUARDAR TICKET   --- *@
    @* =========================================== *@


    @if (mostrarAlertaExito)
    {
        <div class="aviso-todo-salio-bien" role="alert">
            <strong>Ticket ya esta lito :D</strong> 
            <button type="button" class="boton-alerta-adios" @onclick="() => mostrarAlertaExito = false">×</button>
        </div>
    }



    
    


    
  


    <div class="zona-de-trabajo-pesada">


       
       
       
        <div class="columna-formulario">
            <div class="tarjeta-de-pedidos">
                <h3>Compra ahora</h3>


                @* =========================================== *@
                @*      ---   SELECCIÓN DE CLIENTE   --- *@
                @* =========================================== *@


                <div class="campo-inputs">
                    <label>1. Paciente:</label>
                    <select class="cajita-pa-seleccionar" @bind="clienteSeleccionadoId">
                        <option value="0">Cliente</option>
                        @if (clientesLista != null)
                        {
                            @foreach (var cli in clientesLista)
                            {
                                @* ================================================= *@
                                @* --- CON EL ID DEL CLIENTE, COLOCARÁ EL NOMBRE --- *@
                                @* ================================================= *@

                                <option value="@cli.Id">@cli.Nombre</option>
                            }
                        }
                    </select>
                </div>
                
                <div class="campo-inputs">
                    <label>2. Medicamento:</label>

                    @* ============================================= *@
                    @* --- ENTRAR A LA LISTA DE PRODUCTOS (API)  --- *@
                    @* ============================================= *@

                    <select class="control-input" @onchange="OnProductoSelected">
                        <option value="0">Selecciona un medicamento D:</option>
                        @if (productosApiLista != null)
                        {
                            @foreach (var prod in productosApiLista)
                            {
                                @* =========================================== *@
                                @*     --- GUARDA EL: NOMBRE Y PRECIO      --- *@
                                @* =========================================== *@

                                <option value="@prod.Id">
                                    @prod.nombre  - (@prod.precio.ToString("0.00 MXN"))
                                </option>
                            }
                        }
                    </select>
                </div>

                @* =========================================================== *@
                @*   --- SI PRODUCTO ESTÁ SELECCIONADO Y REQUIERE RECETA   --- *@
                @* =========================================================== *@

                @if (productoSeleccionado != null && productoSeleccionado.requierereceta)
                {

                    <div class=" peligro-de-receta" role="alert">
                        <i class="bi bi-exclamation-diamond-fill"></i> <strong>Atención:</strong> Necesitas receta médica, lo siento
                    </div>
                }

                @* ============================================ *@
                @*   --- GUARDAR LA CANTIDAD SELECCIONADA   --- *@
                @* ============================================ *@

                <div class="campo-inputs">
                    <label>3. Cantidad:</label>
                    <input type="number" class="cajita-pa-seleccionar" @bind-value="cantidadIngresada" min="1" />
                </div>

                @* ============================================ *@
                @*   ---    BOTÓN PARA AGREGAR AL TICKET    --- *@
                @* ============================================ *@

                @* Disabled: permite desactivar el botón si no hay producto seleccionado *@
                <button class="boton-ticket-pagar" @onclick="AgregarAlCarrito" disabled="@(productoSeleccionado == null)">
                    <i class="bi bi-plus-circle-fill"></i> Realizar compra
                </button>
            </div>
        </div>

       
        

        @* ============================================ *@
        @*  ---    PRODUCTOS AGREGADOS EN TU COMRA  --- *@
        @* ============================================ *@

        
       
        <div class="columna-carrito">

            <div class="tarjeta-del-super">
                <h3>Artículos en el Ticket Actual</h3>

                

                <div class="tabla-responsiva">


                    <table class="tabla-tickets-compras">

                        @* ============================================ *@
                        @*   ---        NOMBRE DE LOS CAMPOS        --- *@
                        @* ============================================ *@

                        <thead>
                            <tr>
                                <th>Nombre</th>
                                <th>Laboratorio</th>                 
                                <th>Cantidad selecccionada</th>
                                <th>Precio por Unidad</th>
                                <th>Total</th>
                                <th>Eliminar</th>
                            </tr>
                        </thead>   
                        <tbody>

                            @*Si NO hay productos en el carrito...*@
                            @if (!carritoAuxiliar.Any())
                            {
                                <tr>
                                    <td colspan="6" class="tabla-sin-nada">
                                        <i class="bi bi-cart-x"></i> Agrega productos para empezar :D
                                    </td>
                                </tr>
                            }
                            else @*Si hay productos en el carrito...*@
                            {
                                @foreach (var item in carritoAuxiliar)
                                {
                                    <tr>
                                        <td class="texto-destacado">
                                            @item.NombreTemporal
                                            @if (item.RequiereRecetaTemporal)
                                            {
                                                <span class="etiqueta-del-doctor ">Receta</span>
                                            }
                                        </td>
                                        <td>@item.LaboratorioTemporal</td>
                                        <td>@item.Detalle.Cantidad</td>
                                        <td>@item.Detalle.Precio.ToString("$#,##0.00 MXN")</td>
                                        <td>@((item.Detalle.Cantidad * item.Detalle.Precio).ToString("$#,##0.00 MXN"))</td>
                                        <td>
                                            @*Boton para quitar item (producto)*@
                                            <button class="boton-quitar-producto " @onclick="() => EliminarDelCarrito(item)">
                                                <i class="bi bi-trash-fill"></i>
                                            </button>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
                
                @* ============================================ *@
                @* --- TOTAL A PAGAR  (TODO LOS PRODUCTOS) ---  *@
                @* ============================================ *@
                
                <div class="zona-de-pagar-abajo">
                    <div class="caja-dinero">
                        <h3 class="numerote-del-dinero">@totalVenta.ToString("$#,##0.00 MXN")</h3>
                    </div>


                    <button class="boton-guardado" @onclick="GuardarTicketEnAzure" disabled="@(clienteSeleccionadoId == 0 || !carritoAuxiliar.Any())">
                        <i class="bi bi-printer-fill"></i> Guardar 
                    </button>

                </div>

            </div>
        </div>
    </div>
    
    
    @* ============================================ *@
    @* ---    TABLA DE HISTORIAL DE TICKETS   ---   *@
    @* ============================================ *@

  
    <div class="tarjeta-de-tickets">

        <h3><i class="bi bi-receipt-cutoff"></i> Historial de Tickets</h3>
        <hr />

        @*Si no hay tickets en el historial...*@
        @if (historialTickets == null)
        {
            <p class="texto-cargando">Cargando...</p>
        }

        @*Una vez que se han cargado los tickets y no hay ninguno...*@
        else if (!historialTickets.Any())
        {
            <div class="nada-historial">
                No hay tickets registrados
            </div>
        }
        else @*Si hay tickets en el historial...*@
        {

            @* ============================================ *@
            @* ---       TABLA DE LOS TICKETS         ---   *@
            @* ============================================ *@

            <div class="tabla-responsiva">
                <table class="tabla-tickets-historial">
                    <thead>
                        <tr>
                            <th>Ticket</th>
                            <th>Fecha</th>
                            <th>Cliente</th>
                            <th>Detalle</th>
                            <th>Total</th>
                        </tr>
                    </thead>
                    <tbody>
                        
                        @*Recorrido por cada ticket en el historial*@
                        @foreach (var t in historialTickets)
                        {
                            <tr>
                                <td class="ticket-id">#@t.Id</td>
                                <td>@t.Fecha.ToString("dd/MM/yyyy")</td>
                                @*Busca el cliente asociado al detalle en la BD(izquierda). si no lo tiene le pone "Cliente General"(derecha)*@
                                <td class="texto-destacado">@(t.Cliente?.Nombre ?? "Cliente General")</td>
                                <td>
                                    <ul class="detalles-historial">
                                        @*Recorrido por cada detalle en el ticket*@
                                        @foreach (var det in t.Detalles)
                                        {
                                            <li>
                                                <i class="bi bi-arrow-right-short"></i>
                                           
                                                <span class="precio-historial">@det.Precio.ToString("0.00 MXN")</span>
                                            </li>
                                        }
                                    </ul>
                                </td>
                                <td class="total-historial">@t.Total.ToString("0.00 MXN")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>


    <footer>
        <p>&copy; 2026 Farmacias Similares. Todos los derechos reservados.</p>
    </footer>

@code {

    





    // ===========================================================================
    // --- VARIABLES Y PROPIEDADES LOCALES ---
    // ===========================================================================


    private List<Cliente>? clientesLista; // Cargada desde Azure SQL al iniciar la página
    private List<ProductoTodos>? productosApiLista; // Cargada desde la API externa al iniciar la página
    private List<Ticket>? historialTickets; // Cargada desde Azure SQL al iniciar la página, incluye detalles y cliente asociado

    private int clienteSeleccionadoId = 0; // Se asigna al seleccionar un cliente del dropdown, 0 significa "no seleccionado"
    private ProductoTodos? productoSeleccionado; // Se asigna al seleccionar un producto de la API
    private int cantidadIngresada = 1;


    private class ItemCarrito
    {
        public string NombreTemporal { get; set; } = "";
        public string LaboratorioTemporal { get; set; } = "";
        public bool RequiereRecetaTemporal { get; set; }
        public DetalleTicket Detalle { get; set; } = new(); // Solo se llena el ProductoApiId, Cantidad y Precio. El TicketId se asigna al guardar el ticket completo.
    }

    private List<ItemCarrito> carritoAuxiliar = new List<ItemCarrito>(); // Lista temporal que representa los productos que se están agregando al ticket actual antes de guardarlo en Azure SQL
    private decimal totalVenta => carritoAuxiliar.Sum(x => x.Detalle.Cantidad * x.Detalle.Precio); // Propiedad calculada que suma el total de la venta actual en base a los items del carrito
    private bool mostrarAlertaExito = false; // Controla la visibilidad de la alerta de éxito al guardar un ticket

    private const string UrlProductosSalud = "https://api-udec-pweb-aedec9hxbugye0am.westus3-01.azurewebsites.net/api/salud/productos";

    protected override async Task OnInitializedAsync()
    {
        await CargarDatosIniciales();
    }

    private async Task CargarDatosIniciales()
    {
 
        try
        {
            // Cargamos los clientes
            clientesLista = await DbContext.ClientesF.OrderBy(c => c.Nombre).ToListAsync(); // Cargamos los clientes ordenados alfabéticamente para el dropdown

            
            // Para el historial, incluimos la información del cliente y los detalles de cada ticket para poder mostrarlo en la tabla
            historialTickets = await DbContext.TicketsF
                .Include(t => t.Cliente)
                .Include(t => t.Detalles)
                .OrderByDescending(t => t.Fecha)
                .ToListAsync(); // Cargamos los tickets con su cliente asociado y los detalles para mostrar en el historial
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error al cargar datos de la BD: {ex.Message}");
        }

     
        try
        {
            // Cargamos la lista de productos desde la API externa al iniciar la página
            productosApiLista = await Http.GetFromJsonAsync<List<ProductoTodos>>(UrlProductosSalud);
        }
        catch (Exception ex)
        {
        
            productosApiLista = new List<ProductoTodos>(); // Si la API no responde, inicializamos la lista vacía para evitar que la página se rompa y mostrar un mensaje de error en la consola
            Console.WriteLine($"La API no funciona D: {ex.Message}");
        }
    }


    private string ObtenerNombreProducto(int apiId)
    {
        var prod = productosApiLista?.FirstOrDefault(p => p.Id == apiId); // Buscamos el producto en la lista cargada desde la API para mostrar su nombre y presentación en el historial
        return prod != null ? $"{prod.nombre} ({prod.presentacion})" : $" (ID: {apiId})";
    }


    // ===========================================================================
    // --- MÉTODOS DE INTERACCIÓN Y LÓGICA DE NEGOCIO ---
    // ===========================================================================


    //  Este método se ejecuta cada vez que el usuario selecciona un producto diferente en el dropdown de productos (API). Su función es actualizar la variable "productoSeleccionado" con la información completa del producto elegido para mostrarla en el formulario y usarla al agregar al carrito.
    private void OnProductoSelected(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int id) && id > 0) // Validamos que el valor seleccionado sea un número entero válido y mayor a 0 (0 es la opción de "no seleccionar")
        {
            productoSeleccionado = productosApiLista?.FirstOrDefault(p => p.Id == id); // Buscamos el producto seleccionado en la lista cargada desde la API para obtener su información completa (nombre, precio, si requiere receta, etc.) y mostrarla en el formulario
        }
        else
        {
            productoSeleccionado = null; // Si no se selecciona un producto válido, reseteamos la variable para que el formulario se actualice y no muestre información de un producto anterior
        }
    }

    private void AgregarAlCarrito()
    {

        // Validamos que se haya seleccionado un producto y que la cantidad ingresada sea mayor a 0 antes de agregar al carrito
        if (productoSeleccionado != null && cantidadIngresada > 0)
        {
            var itemExistente = carritoAuxiliar.FirstOrDefault(x => x.Detalle.ProductoApiId == productoSeleccionado.Id); // Verificamos si el producto seleccionado ya existe en el carrito para sumar la cantidad en lugar de agregar un nuevo item

            if (itemExistente != null) // Si el producto ya está en el carrito, simplemente sumamos la cantidad ingresada a la cantidad existente en ese item
            {
                itemExistente.Detalle.Cantidad += cantidadIngresada;
            }
            else
            {
                carritoAuxiliar.Add(new ItemCarrito
                {
                    NombreTemporal = productoSeleccionado.nombre,
                    LaboratorioTemporal = productoSeleccionado.laboratorio,
                    RequiereRecetaTemporal = productoSeleccionado.requierereceta,
                    Detalle = new DetalleTicket // Creamos un nuevo detalle de ticket con la información del producto seleccionado y la cantidad ingresada para agregarlo al carrito
                    {
                        ProductoApiId = productoSeleccionado.Id,
                        Cantidad = cantidadIngresada,
                        Precio = productoSeleccionado.precio
                    }
                });
            }

            cantidadIngresada = 1;
        }
    }

    private void EliminarDelCarrito(ItemCarrito item)
    {
        carritoAuxiliar.Remove(item);
    }

    private async Task GuardarTicketEnAzure()
    {
        if (clienteSeleccionadoId == 0 || !carritoAuxiliar.Any()) return; // Validamos que se haya seleccionado un cliente y que haya al menos un producto en el carrito antes de intentar guardar el ticket

        try
        {
            var nuevoTicket = new Ticket // Creamos un nuevo ticket con la información del cliente seleccionado, la fecha actual, el total calculado y un estado de "Pagado" para indicar que la venta se ha cerrado
            {
                ClienteId = clienteSeleccionadoId,
                Fecha = DateTime.Now,
                Total = totalVenta,
                Estado = "Pagado"
            };

            DbContext.TicketsF.Add(nuevoTicket); // Agregamos el nuevo ticket al contexto de la base de datos para que se le asigne un ID al guardarlo, lo cual es necesario para relacionar los detalles con este ticket
            await DbContext.SaveChangesAsync();

            foreach (var item in carritoAuxiliar) // Recorremos cada item del carrito para crear un detalle de ticket asociado al nuevo ticket que acabamos de guardar. Asignamos el TicketId del detalle al ID del nuevo ticket para establecer la relación en la base de datos.
            {
                item.Detalle.TicketId = nuevoTicket.Id; // Asignamos el TicketId del detalle al ID del nuevo ticket para establecer la relación en la base de datos
                DbContext.DetalleTicketsF.Add(item.Detalle); // Agregamos cada detalle al contexto de la base de datos para que se guarden junto con el ticket
            } 

            await DbContext.SaveChangesAsync();

            await CargarDatosIniciales(); // Recargamos los datos iniciales para actualizar el historial de tickets con el nuevo ticket que acabamos de guardar y reflejar cualquier cambio en la lista de clientes o productos si es necesario

            carritoAuxiliar.Clear();
            clienteSeleccionadoId = 0;
            productoSeleccionado = null;
            mostrarAlertaExito = true;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error con Azure: {ex.Message}");
        }
    }
}