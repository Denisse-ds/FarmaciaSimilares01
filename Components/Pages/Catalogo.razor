@page "/catalogo"
@inject HttpClient Http
@using FarmaciaSimilares01.Models

<PageTitle>Farmacia Similares</PageTitle>

    <header>

        <nav class="nav-page">
            <ul>
                <div class="logo-img">
                    <img src="/img/logo-similares.png" alt="">
                </div>
                <li><a href="/">Inicio</a></li>
                <li><a href="/catalogo">Catálogo</a></li>
                <li><a href="/sistemaCRUD">Registrarte</a></li>
            <li><a href="/venta">Historial</a></li>
            </ul>

        </nav>

    </header>

    <main>
        <h2 class="titulo-seccion">Catálogo de Productos</h2>

        <div class="dividir-pantalla">

            <aside>
                <div class="filtros-container">
                    <button class="btn @(modoVista == "Todos" ? "btn-activo" : "btn-inactivo")" @onclick="CargarTodos">
                        Todos los Productos
                    </button>
                    <button class="btn @(modoVista == "SinReceta" ? "btn-activo" : "btn-inactivo")" @onclick="CargarSinReceta">
                        Sin Receta
                    </button>
                </div>

                <div class="especialidades-container">
                    <h4>Filtrar por Especialidad:</h4>
                    <div class="checkbox-grid">
                        @if (listaEspecialidades != null)
                        {
                            @foreach (var esp in listaEspecialidades)
                            {
                                <label class="checkbox-label">
                                    <input type="checkbox" value="@esp.Id" @onchange="(e) => AlCambiarEspecialidad(esp.Id, e.Value)" checked="@especialidadesSeleccionadas.Contains(esp.Id)" />
                                    <span class="custom-checkbox"></span>
                                    @esp.nombre
                                </label>
                            }
                        }
                        else
                        {
                            <span class="cargando-texto">Cargando especialidades...</span>
                        }
                    </div>
                </div>
            </aside>

            @if (cargando)
            {
                <div class="mensaje-carga">
                    <p>Cargando productos, por favor espera...</p>
                </div>
            }
            else
            {
                <div class="cards-grid">
                    @if (ListaActual != null && ListaActual.Any())
                    {
                        @foreach (var prod in ListaActual)
                        {
                            <div class="card">
                                <div class="card-header">
                                    @if (modoVista == "Todos" || modoVista == "Especialidad")
                                    {
                                        @if (prod.requierereceta)
                                        {
                                            <span class="badge-receta-si">Requiere Receta</span>
                                        }
                                        else
                                        {
                                            <span class="badge-receta-no">No requiere receta</span>
                                        }
                                    }
                                    @* <span class="card-id">(@prod.Id)</span>*@
                                </div>
                                <div class="card-body">
                                    <h3 class="producto-nombre">@prod.nombre</h3>
                                    <p class="producto-detalle"><strong>Laboratorio:</strong> @prod.laboratorio</p>
                                    <p class="producto-detalle"><strong>Presentación:</strong> @prod.presentacion</p>
                                    <p class="producto-especialidad">@prod.especialidad</p>
                                </div>
                                <div class="card-footer">
                                    <span class="producto-precio">$@prod.precio</span>
                                    @*  <button class="btn-comprar">Agregar</button>*@
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div style="grid-column: 1 / -1; text-align: center; padding: 40px;">
                            <p>No se encontraron productos</p>
                        </div>
                    }
                </div>
            }
        </div>
    </main>
    <footer>
        <p>&copy; 2026 Farmacias Similares. Todos los derechos reservados.</p>
    </footer>



@code {

    // ===================================================================
    //   VARIABLES Y PROPIEDADES
    // ===================================================================



    private List<ProductoTodos>? listaTodos; // Cache para "Todos los productos"
    private List<SinReceta>? listaSinReceta; // Cache para "Sin receta"
    private List<Especialidad>? listaEspecialidades; // Cache para especialidades

    private IEnumerable<dynamic>? ListaActual; // Lista que se muestra actualmente (puede ser de cualquiera de los tipos)

 
    private string modoVista = "Todos"; // "Todos", "SinReceta" o "Especialidad", inicialmente en "Todos"
    private bool cargando = true; // Indicador de carga para mostrar mensaje mientras se obtienen datos


    private List<int> especialidadesSeleccionadas = new List<int>(); // IDs de especialidades seleccionadas para filtrar

    // API Endpoints
    private string urlTodos = "https://api-udec-pweb-aedec9hxbugye0am.westus3-01.azurewebsites.net/api/salud/productos";
    private string urlSinReceta = "https://api-udec-pweb-aedec9hxbugye0am.westus3-01.azurewebsites.net/api/salud/productos/sinreceta";
    private string urlEspecialidades = "https://api-udec-pweb-aedec9hxbugye0am.westus3-01.azurewebsites.net/api/salud/especialidades";
    private string urlFiltroEspecialidadBase = "https://api-udec-pweb-aedec9hxbugye0am.westus3-01.azurewebsites.net/api/salud/productos/especialidad/";



    // ===================================================================
    //  CARGA INICIAL Y FUNCIONES DE CARGA
    // ===================================================================


    // Carga inicial: obtenemos especialidades y todos los productos
    protected override async Task OnInitializedAsync()
    {
        try
        {
            // Cargamos especialidades para el filtro lateral
 
            listaEspecialidades = await Http.GetFromJsonAsync<List<Especialidad>>(urlEspecialidades);
        }
        catch (Exception ex)
        {
            // Si falla la carga de especialidades, inicializamos la lista vacía para evitar errores en la UI
            Console.WriteLine($"Error al cargar especialidades: {ex.Message}");
            listaEspecialidades = new List<Especialidad>(); // Evita que la UI se rompa si no se pueden cargar las especialidades
        }

        await CargarTodos(); // Carga inicial de todos los productos
    }


    // ===================================================================
    // FUNCIONES DE CARGA Y FILTRADO
    // ===================================================================

    private async Task CargarTodos()
    {
        cargando = true; // Activamos indicador de carga
        modoVista = "Todos"; // Cambiamos modo de vista para mostrar que estamos en "Todos los productos"
        especialidadesSeleccionadas.Clear(); // Limpiamos selección, PORQUE SI ESTAMOS EN "TODOS", NO DEBERÍA HABER NINGUNA ESPECIALIDAD SELECCIONADA

        try
        {
            // Si ya tenemos los productos en cache, no hacemos la llamada a la API de nuevo
            if (listaTodos == null)
                listaTodos = await Http.GetFromJsonAsync<List<ProductoTodos>>(urlTodos); // Carga desde API solo la primera vez

            ListaActual = listaTodos; // Asignamos la lista de productos a la variable que se muestra en la UI
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error al cargar todos los productos: {ex.Message}");
        }
        finally
        {
            cargando = false; // Desactivamos indicador de carga, ya sea que la carga haya sido exitosa o haya fallado
        }
    }

    // ==================================================================
    // FUNCIONES DE FILTRADO POR ESPECIALIDAD Y SIN RECETA
    // ==================================================================

    private async Task CargarSinReceta()
    {
        // Lo miismo que en CargarTodos pero para la vista de "Sin receta"
        cargando = true;
        modoVista = "SinReceta";
        especialidadesSeleccionadas.Clear();

        try
        {
            if (listaSinReceta == null)
                listaSinReceta = await Http.GetFromJsonAsync<List<SinReceta>>(urlSinReceta);

            ListaActual = listaSinReceta;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error al cargar productos sin receta: {ex.Message}");
        }
        finally
        {
            cargando = false;
        }
    }

    // Esta función se llama cada vez que el usuario marca o desmarca una especialidad en el filtro lateral
    private async Task AlCambiarEspecialidad(int especialidadId, object? isChecked)
    {
        bool marcado = (bool)(isChecked ?? false); // Convertimos el valor del checkbox a booleano, por si acaso viene nulo

        if (marcado) //si marcado = true, es decir, si el usuario acaba de marcar esta especialidad, la agregamos a la lista de seleccionadas
        {
            especialidadesSeleccionadas.Add(especialidadId);
        }
        else // si marcado = false, es decir, si el usuario acaba de desmarcar esta especialidad, la quitamos de la lista de seleccionadas
        {
            especialidadesSeleccionadas.Remove(especialidadId);
        }

        await BuscarPorEspecialidades(); // Después de actualizar la lista de especialidades seleccionadas, llamamos a la función que hace la consulta a la API para obtener los productos que coinciden con las especialidades seleccionadas
    }


    // Esta función hace la consulta a la API para obtener los productos que coinciden con las especialidades seleccionadas. Si no hay ninguna especialidad seleccionada, carga todos los productos.
    private async Task BuscarPorEspecialidades()
    {
        if (!especialidadesSeleccionadas.Any()) //  Si no hay ninguna especialidad seleccionada, volvemos a cargar todos los productos (podríamos optimizar esto para no hacer la consulta de nuevo si ya tenemos los productos en cache, pero por simplicidad vamos a llamar a CargarTodos que ya maneja eso)
        {
            await CargarTodos();
            return;
        }


        cargando = true; 
        modoVista = "Especialidad";
        var resultadosCombinados = new List<ProductoTodos>(); // Lista temporal para almacenar los resultados combinados de todas las especialidades seleccionadas

        try
        {
            foreach (var id in especialidadesSeleccionadas) // Para cada especialidad seleccionada, hacemos una consulta a la API para obtener los productos que pertenecen a esa especialidad
            {
                var urlConsulta = $"{urlFiltroEspecialidadBase}{id}"; // Construimos la URL de consulta para esta especialidad
                var productosEspecialidad = await Http.GetFromJsonAsync<List<ProductoTodos>>(urlConsulta);

                if (productosEspecialidad != null) // Si la consulta fue exitosa y obtuvimos productos para esta especialidad, los agregamos a la lista de resultados combinados
                {
                    resultadosCombinados.AddRange(productosEspecialidad);
                }
            }

            ListaActual = resultadosCombinados; // Asignamos la lista de resultados combinados a la variable que se muestra en la UI. Esta lista contiene todos los productos que pertenecen a cualquiera de las especialidades seleccionadas
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error al filtrar por especialidad: {ex.Message}");
        }
        finally
        {
            cargando = false;
        }
    }
}