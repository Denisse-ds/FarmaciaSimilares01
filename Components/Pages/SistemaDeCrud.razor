@page "/sistemaCRUD"
@using FarmaciaSimilares01.Models
@using FarmaciaSimilares01.Data
@inject MedicamentosDbContext db
@* IJSRuntime JS Lo que hace es para interacciones con el entorno del navegador, por ejemplo, para mostrar alertas o mensajes de confirmación *@
@inject IJSRuntime JS  
@using Microsoft.EntityFrameworkCore
@rendermode InteractiveServer

<PageTitle>Farmacia Similares</PageTitle>

<header>
    <nav class="nav-page">
        <ul>
            <div class="logo-img">
                <img src="/img/logo-similares.png" alt="">
            </div>
            <li><a href="/">Inicio</a></li>
            <li><a href="/catalogo">Catálogo</a></li>
            <li><a href="/sistemaCRUD">Registrarte</a></li>
            <li><a href="/venta">Historial</a></li>
        </ul>
    </nav>
</header>

<h1 class="titulo-seccion">Sistema de Registro de Clientes</h1>

<main>
    @*================================================================================    AGREGAR CLIENTE    =================================================================================*@
    <form>
        <div class="form-group">
            <label for="nombre">Nombre:</label>
            <input type="text" id="nombre" name="nombre" class="form-control" placeholder="Ingresa tu nombre" required @bind="nuevoCliente.Nombre">

            <label for="telefono">Número de teléfono:</label>
            <input type="text" id="telefono" name="telefono" class="form-control" placeholder="Ingresa tu número de teléfono" required @bind="nuevoCliente.Telefono">

            <label for="correo">Correo electrónico:</label>
            <input type="email" id="correo" name="correo" class="form-control" placeholder="Ingresa tu correo electrónico" required @bind="nuevoCliente.Email">

            <label for="fechaRegistro">Fecha de registro:</label>
            <input type="date" id="fechaRegistro" name="fechaRegistro" class="form-control" required @bind="nuevoCliente.FechaRegistro">

            <button type="button" class="btn btn-primary" @onclick="AgregarCliente">Registrarte</button>
        </div>
    </form>

    @*================================================================================    MOSTRAR CLIENTE    =================================================================================*@
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Id</th>
                <th>Nombre</th>
                <th>Teléfono</th>
                <th>Correo</th>
                <th>Fecha de registro</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var cliente in clientes)
            {
                <tr>
                    <td>@cliente.Id</td>
                    <td>@cliente.Nombre</td>
                    <td>@cliente.Telefono</td>
                    <td>@cliente.Email</td>
                    <td>@cliente.FechaRegistro.ToShortDateString()</td>
                    <td>
                        <button class="btn btn-sm btn-warning" @onclick="() => IniciarEdicion(cliente)">
                            <i class="fas fa-edit"></i>
                        </button>
                        <button class="btn btn-sm btn-danger" @onclick="() => EliminarCliente(cliente)">
                            <i class="fas fa-trash"></i>
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    @*================================================================================    EDITAR CLIENTE    =================================================================================*@
    @if (clienteEnEdicion != null)
    {
        <form>
            <div class="form-group">
                <h3>Editar Cliente: @clienteEnEdicion.Nombre</h3>

                <label for="edit-nombre">Nombre:</label>
                <input type="text" id="edit-nombre" name="nombre" class="form-control" placeholder="Ingresa tu nombre" required @bind="clienteEnEdicion.Nombre">

                <label for="edit-telefono">Número de teléfono:</label>
                <input type="text" id="edit-telefono" name="telefono" class="form-control" placeholder="Ingresa tu número de teléfono" required @bind="clienteEnEdicion.Telefono">

                <label for="edit-correo">Correo electrónico:</label>
                <input type="email" id="edit-correo" name="correo" class="form-control" placeholder="Ingresa tu correo electrónico" required @bind="clienteEnEdicion.Email">

                <label for="edit-fechaRegistro">Fecha de registro:</label>
                <input type="date" id="edit-fechaRegistro" name="fechaRegistro" class="form-control" required @bind="clienteEnEdicion.FechaRegistro">

                <button type="button" class="btn btn-success" @onclick="GuardarEdicion">Guardar cambios</button>
                <button type="button" class="btn btn-secondary" @onclick="CancelarEdicion">Cancelar</button>
            </div>
        </form>
    }
</main>

<footer>
    <p>&copy; 2026 Farmacias Similares. Todos los derechos reservados.</p>
</footer>

@code {
    /*================================================================================
                                        VARIABLES
     =================================================================================*/
    private Cliente nuevoCliente = new Cliente() { FechaRegistro = DateTime.Today };
    private List<Cliente> clientes = new List<Cliente>();
    private Cliente? clienteEnEdicion = null;

    protected override async Task OnInitializedAsync()
    {
        await cargarClientes();
    }

    private async Task cargarClientes()
    {
        clientes = await db.ClientesF.ToListAsync();
    }

    /*================================================================================
                                          AGREGAR CLIENTE (Validado)
     =================================================================================*/

    private async Task AgregarCliente()
    {
        // Revisamos que ninguno de los campos de texto esté vacío o tenga puros espacios
        if (string.IsNullOrWhiteSpace(nuevoCliente.Nombre) ||
            string.IsNullOrWhiteSpace(nuevoCliente.Telefono) ||
            string.IsNullOrWhiteSpace(nuevoCliente.Email))
        {
            // Si falta alguno, le mandamos una alerta al usuario y detenemos el código con un "return"
            await JS.InvokeVoidAsync("alert", " Debes completar todos los campos del formulario antes de registrarte.");
            return;
        }

        // Si el código pasa de la condición de arriba, significa que todo está lleno y procede a guardar:
        db.ClientesF.Add(nuevoCliente);// Agregamos el nuevo cliente al contexto de la base de datos
        await db.SaveChangesAsync();
        await cargarClientes();

        // Reiniciamos el formulario limpio para el siguiente registro
        nuevoCliente = new Cliente() { FechaRegistro = DateTime.Today };
    }

    /*================================================================================
                                      EDITAR CLIENTE
    =================================================================================*/
    private void IniciarEdicion(Cliente cliente)
    {
        clienteEnEdicion = cliente;
    }

    private async Task GuardarEdicion()
    {
        if (clienteEnEdicion != null)
        {
            await db.SaveChangesAsync();// Guardamos los cambios en la base de datos
            clienteEnEdicion = null;// Salimos del modo edición
            await cargarClientes();// Recargamos la lista para reflejar los cambios
        }
    }

    private void CancelarEdicion()
    {
        clienteEnEdicion = null;
    }

    /*================================================================================
                                     ELIMINAR CLIENTE
   =================================================================================*/
    private async Task EliminarCliente(Cliente cliente)
    {
        // Despliega una alerta emergente en el navegador con botones de Aceptar y Cancelar
        bool confirmado = await JS.InvokeAsync<bool>("confirm", $"¿Realmente deseas eliminar al cliente \"{cliente.Nombre}\"?");

        // Si el usuario presiona "Aceptar", confirmado será true e ingresará al bloque de borrado
        if (confirmado)
        {
            db.ClientesF.Remove(cliente);
            await db.SaveChangesAsync();
            await cargarClientes();
        }
    }
}